<Window x:Class="Mideej.Views.VolumeOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        Width="600"
        Height="120">
    <Grid>
        <skia:SKElement x:Name="OverlayCanvas" PaintSurface="OverlayCanvas_PaintSurface" />
    </Grid>
</Window>
